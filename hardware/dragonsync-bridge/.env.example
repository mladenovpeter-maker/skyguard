# Copy this file to .env, fill in the values, then `source .env` before
# running bridge.py (or set the same variables in the systemd unit file).

# MQTT broker that DragonSync publishes to (usually mosquitto on the same
# Linux server as DragonSync, so 127.0.0.1 is typical).
MQTT_HOST=127.0.0.1
MQTT_PORT=1883
MQTT_TOPIC=wardragon/drones
# MQTT_USERNAME=
# MQTT_PASSWORD=

# SkyGuard OS API server base URL (no trailing slash).
# Use the app's real domain once deployed; for local testing against the
# Replit dev server use the https://<repl-dev-domain> value.
SKYGUARD_API_BASE=https://your-skyguard-domain.example.com

# Device API key issued from the SkyGuard Admin panel (Admin > Add Device).
# Shown only once at creation - store it here, not in the app itself.
SKYGUARD_DEVICE_KEY=sg_replace_me

# Minimum seconds between forwarded updates for the same drone id.
MIN_POST_INTERVAL_S=2
