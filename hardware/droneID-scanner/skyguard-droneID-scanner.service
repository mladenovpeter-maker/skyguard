[Unit]
Description=SkyGuard OS — DroneID BLE Scanner (nRF52840)
After=network.target bluetooth.target
Wants=bluetooth.target

[Service]
Type=simple
User=admin
WorkingDirectory=/home/admin/skyguard/hardware/droneID-scanner
EnvironmentFile=/home/admin/skyguard/hardware/droneID-scanner/.env
ExecStart=/home/admin/hackrf_sweep/venv/bin/python3 /home/admin/skyguard/hardware/droneID-scanner/scanner.py
Restart=always
RestartSec=5
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
