# ZMQ PUB socket that gr-DroneID publishes decoded frames on
ZMQ_ENDPOINT=tcp://127.0.0.1:4224

# If gr-DroneID runs on a different host (e.g. Pi on roof):
# ZMQ_ENDPOINT=tcp://192.168.1.42:4224

# SkyGuard OS API — your deployed app URL (no trailing slash)
SKYGUARD_API_BASE=https://your-app.example.com

# Device key from SkyGuard Admin → Devices → Add Device
SKYGUARD_DEVICE_KEY=sg_your_key_here

# Throttle: minimum seconds between forwarded updates for the same drone serial
MIN_POST_INTERVAL_S=2

# LOG_LEVEL=DEBUG   # uncomment for verbose output
